# Copy this file to .env and adjust values before running the server.

# Port the server listens on
PORT=3000

# Set to "production" when deploying (enables secure cookies, trust proxy)
NODE_ENV=development

# Long random string used to sign session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=SomethingRandomAndSecure

# Default admin account created the first time the database is seeded.
# Change the password immediately after first login, then these values
# are no longer used (the stored hash in the database is what matters).
ADMIN_USERNAME=ADMIN_Username
ADMIN_PASSWORD=Password

